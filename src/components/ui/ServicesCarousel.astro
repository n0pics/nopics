---
/**
 * ServicesCarousel — Wes Anderson whip-pan carousel
 * 5 theatrical scenes with parallax layers, blur transition,
 * symmetric composition, pastel palette.
 */

interface Scene {
  id: number;
  service: string;
  subtitle: string;
  slug: string;
  bgColor: string;
  accent: string;
  patternColor: string;
}

const scenes: Scene[] = [
  { id: 1, service: 'Réalisation', subtitle: 'Direction artistique et mise en scène', slug: 'realisation-video', bgColor: '#F4CCC1', accent: '#8B3A3A', patternColor: '#EBBDB2' },
  { id: 2, service: 'Clip musical', subtitle: 'Identité visuelle et narration musicale', slug: 'realisation-video', bgColor: '#E8B547', accent: '#2D5F5A', patternColor: '#D4A53E' },
  { id: 3, service: 'Brand content', subtitle: 'Storytelling de marque et contenu premium', slug: 'realisation-video', bgColor: '#A8C4A2', accent: '#D87D5E', patternColor: '#97B691' },
  { id: 4, service: 'Publicité', subtitle: 'Conception et production de spots', slug: 'post-prod', bgColor: '#2B4A6B', accent: '#F0E4C9', patternColor: '#24405D' },
  { id: 5, service: 'Photographie', subtitle: 'Captation et direction photo', slug: 'photographie', bgColor: '#C97B4E', accent: '#6B7A3E', patternColor: '#B86E43' },
];
---

<div class="sc-wrapper" id="sc-wrapper" role="region" aria-label="Carousel de services">
  <div class="sc-track" id="sc-track">
    {scenes.map((scene) => (
      <div
        class="sc-scene"
        data-scene={scene.id}
        style={`--bg: ${scene.bgColor}; --accent: ${scene.accent}; --pattern: ${scene.patternColor};`}
      >
        {/* Background layer — parallax 0.3x */}
        <div class="sc-layer sc-bg">
          <div class="sc-bg-fill"></div>
          {/* Decorative pattern — horizontal lines + vertical symmetry guides */}
          <svg class="sc-pattern" viewBox="0 0 1200 700" preserveAspectRatio="none" aria-hidden="true">
            {/* Horizontal lines */}
            <line x1="0" y1="80" x2="1200" y2="80" stroke="var(--pattern)" stroke-width="1.5" opacity="0.5" />
            <line x1="0" y1="620" x2="1200" y2="620" stroke="var(--pattern)" stroke-width="1.5" opacity="0.5" />
            <line x1="0" y1="160" x2="1200" y2="160" stroke="var(--pattern)" stroke-width="0.5" opacity="0.25" />
            <line x1="0" y1="540" x2="1200" y2="540" stroke="var(--pattern)" stroke-width="0.5" opacity="0.25" />
            {/* Center vertical guide */}
            <line x1="600" y1="0" x2="600" y2="700" stroke="var(--pattern)" stroke-width="0.5" opacity="0.15" />
            {/* Decorative rectangles */}
            <rect x="100" y="100" width="1000" height="500" fill="none" stroke="var(--pattern)" stroke-width="1" opacity="0.2" rx="2" />
            <rect x="140" y="130" width="920" height="440" fill="none" stroke="var(--pattern)" stroke-width="0.5" opacity="0.12" rx="2" />
          </svg>
        </div>

        {/* Midground layer — parallax 0.7x */}
        <div class="sc-layer sc-mid">
          {/* Theatrical curtain sides */}
          <div class="sc-curtain sc-curtain-left"></div>
          <div class="sc-curtain sc-curtain-right"></div>
          {/* Arch frame */}
          <svg class="sc-arch" viewBox="0 0 600 500" aria-hidden="true">
            <path d="M50,500 L50,180 Q50,50 180,50 L420,50 Q550,50 550,180 L550,500" fill="none" stroke="var(--accent)" stroke-width="2" opacity="0.25" />
            <path d="M70,500 L70,190 Q70,70 190,70 L410,70 Q530,70 530,190 L530,500" fill="none" stroke="var(--accent)" stroke-width="1" opacity="0.15" />
          </svg>
        </div>

        {/* Foreground layer — parallax 1x */}
        <div class="sc-layer sc-fg">
          {/* Chapter card */}
          <div class="sc-chapter">Chapitre N&deg;{String(scene.id).padStart(2, '0')}</div>

          {/* Central subject SVG */}
          <div class="sc-subject">
            {scene.id === 1 && (
              <svg viewBox="0 0 120 120" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sc-icon" aria-hidden="true">
                {/* Camera 35mm on tripod */}
                <rect x="25" y="30" width="70" height="45" rx="4" />
                <circle cx="60" cy="52" r="15" />
                <circle cx="60" cy="52" r="8" />
                <rect x="75" y="22" width="20" height="12" rx="2" />
                <line x1="45" y1="75" x2="35" y2="110" />
                <line x1="60" y1="75" x2="60" y2="110" />
                <line x1="75" y1="75" x2="85" y2="110" />
              </svg>
            )}
            {scene.id === 2 && (
              <svg viewBox="0 0 120 120" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sc-icon" aria-hidden="true">
                {/* Chrome microphone on stand */}
                <rect x="48" y="15" width="24" height="40" rx="12" />
                <path d="M42,45 Q42,65 60,65 Q78,65 78,45" />
                <line x1="60" y1="65" x2="60" y2="95" />
                <line x1="45" y1="95" x2="75" y2="95" />
                <line x1="60" y1="95" x2="60" y2="110" />
                <line x1="42" y1="110" x2="78" y2="110" />
              </svg>
            )}
            {scene.id === 3 && (
              <svg viewBox="0 0 120 120" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sc-icon" aria-hidden="true">
                {/* Mannequin */}
                <circle cx="60" cy="22" r="12" />
                <line x1="60" y1="34" x2="60" y2="75" />
                <line x1="60" y1="45" x2="38" y2="60" />
                <line x1="60" y1="45" x2="82" y2="60" />
                <line x1="60" y1="75" x2="42" y2="110" />
                <line x1="60" y1="75" x2="78" y2="110" />
                <ellipse cx="60" cy="55" rx="18" ry="22" stroke-dasharray="4 3" opacity="0.4" />
              </svg>
            )}
            {scene.id === 4 && (
              <svg viewBox="0 0 120 120" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sc-icon" aria-hidden="true">
                {/* Clapperboard */}
                <rect x="20" y="40" width="80" height="60" rx="3" />
                <polygon points="20,40 100,40 100,25 30,25" />
                <line x1="40" y1="25" x2="35" y2="40" />
                <line x1="55" y1="25" x2="50" y2="40" />
                <line x1="70" y1="25" x2="65" y2="40" />
                <line x1="85" y1="25" x2="80" y2="40" />
                <line x1="30" y1="60" x2="90" y2="60" />
                <line x1="30" y1="75" x2="70" y2="75" />
                <circle cx="80" cy="82" r="6" />
              </svg>
            )}
            {scene.id === 5 && (
              <svg viewBox="0 0 120 120" fill="none" stroke="var(--accent)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="sc-icon" aria-hidden="true">
                {/* Analog camera body */}
                <rect x="22" y="35" width="76" height="55" rx="5" />
                <circle cx="60" cy="62" r="18" />
                <circle cx="60" cy="62" r="10" />
                <circle cx="60" cy="62" r="4" />
                <rect x="32" y="25" width="18" height="14" rx="3" />
                <rect x="75" y="40" width="12" height="8" rx="2" />
                <line x1="38" y1="95" x2="38" y2="110" />
                <line x1="82" y1="95" x2="82" y2="110" />
              </svg>
            )}
          </div>

          {/* Title + subtitle */}
          <a href={`/services/${scene.slug}`} class="sc-title-block">
            <h3 class="sc-title" style={`color: ${scene.accent};`}>{scene.service}</h3>
            <p class="sc-subtitle" style={`color: ${scene.accent};`}>{scene.subtitle}</p>
          </a>

          {/* Index */}
          <div class="sc-index" style={`color: ${scene.accent};`}>
            {String(scene.id).padStart(2, '0')} / 05
          </div>
        </div>
      </div>
    ))}
  </div>

  {/* Navigation arrows */}
  <div class="sc-nav">
    <button class="sc-arrow sc-arrow-prev" id="sc-prev" aria-label="Service pr&eacute;c&eacute;dent">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="15 18 9 12 15 6" />
      </svg>
    </button>
    <button class="sc-arrow sc-arrow-next" id="sc-next" aria-label="Service suivant">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="9 6 15 12 9 18" />
      </svg>
    </button>
  </div>
</div>

<style>
  /* ============================================================
     WRAPPER
     ============================================================ */
  .sc-wrapper {
    position: relative;
    width: 100vw;
    height: 70vh;
    overflow: hidden;
    background: #1a1a1a;
  }

  /* ============================================================
     TRACK — holds all scenes side by side
     ============================================================ */
  .sc-track {
    display: flex;
    width: 500vw; /* 5 scenes */
    height: 100%;
    will-change: transform, filter;
    transition: transform 450ms cubic-bezier(0.7, 0, 0.3, 1),
                filter 200ms ease;
  }

  .sc-track.is-panning {
    filter: blur(14px) saturate(1.15);
  }

  /* ============================================================
     SCENE — each full-width panel
     ============================================================ */
  .sc-scene {
    position: relative;
    width: 100vw;
    height: 100%;
    flex-shrink: 0;
    overflow: hidden;
  }

  /* ============================================================
     PARALLAX LAYERS
     ============================================================ */
  .sc-layer {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    will-change: transform;
    transition: transform 450ms cubic-bezier(0.7, 0, 0.3, 1);
  }

  /* ============================================================
     BACKGROUND LAYER (0.3x parallax)
     ============================================================ */
  .sc-bg {
    z-index: 0;
  }

  .sc-bg-fill {
    position: absolute;
    inset: 0;
    background: var(--bg);
  }

  .sc-pattern {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* ============================================================
     MIDGROUND LAYER (0.7x parallax)
     ============================================================ */
  .sc-mid {
    z-index: 1;
    pointer-events: none;
  }

  .sc-curtain {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 8%;
    background: linear-gradient(
      180deg,
      var(--accent) 0%,
      transparent 100%
    );
    opacity: 0.08;
  }

  .sc-curtain-left { left: 0; }
  .sc-curtain-right { right: 0; }

  .sc-arch {
    width: min(50%, 500px);
    height: auto;
    opacity: 0.6;
  }

  /* ============================================================
     FOREGROUND LAYER (1x parallax)
     ============================================================ */
  .sc-fg {
    z-index: 2;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2.5rem 3rem;
  }

  /* Chapter card */
  .sc-chapter {
    position: absolute;
    top: 2.5rem;
    left: 3rem;
    font-family: var(--font-body);
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--accent);
    opacity: 0.5;
  }

  /* Central SVG subject */
  .sc-subject {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sc-icon {
    width: clamp(80px, 12vw, 130px);
    height: clamp(80px, 12vw, 130px);
    opacity: 0.7;
  }

  /* Title block */
  .sc-title-block {
    text-align: center;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    transition: opacity 0.3s ease;
  }

  .sc-title-block:hover {
    opacity: 0.7;
  }

  .sc-title {
    font-family: var(--font-body);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
    line-height: 1.1;
  }

  .sc-subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.75rem, 1.5vw, 1rem);
    font-weight: 400;
    margin: 0;
    opacity: 0.6;
    text-transform: lowercase;
  }

  /* Index */
  .sc-index {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    opacity: 0.4;
  }

  /* ============================================================
     NAVIGATION ARROWS
     ============================================================ */
  .sc-nav {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 3rem;
    z-index: 10;
  }

  .sc-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1.5px solid rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.25);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: rgba(255, 255, 255, 0.8);
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease;
  }

  .sc-arrow:hover {
    background: rgba(255, 255, 255, 0.15);
    color: #ffffff;
    border-color: #ffffff;
  }

  /* ============================================================
     REDUCED MOTION
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .sc-track {
      transition: transform 200ms ease, filter 0ms;
    }
    .sc-track.is-panning {
      filter: none;
    }
    .sc-layer {
      transition: none;
    }
  }

  /* ============================================================
     RESPONSIVE
     ============================================================ */
  @media (max-width: 768px) {
    .sc-wrapper {
      height: 75vh;
    }

    .sc-chapter {
      top: 1.5rem;
      left: 1.5rem;
      font-size: 0.55rem;
    }

    .sc-fg {
      padding: 1.5rem;
    }

    .sc-nav {
      bottom: 1.5rem;
      gap: 2rem;
    }

    .sc-arrow {
      width: 40px;
      height: 40px;
    }

    .sc-curtain {
      width: 5%;
    }
  }
</style>

<script>
  const wrapper = document.getElementById('sc-wrapper');
  const track = document.getElementById('sc-track');
  const prevBtn = document.getElementById('sc-prev');
  const nextBtn = document.getElementById('sc-next');

  if (track && wrapper) {
    const TOTAL = 5;
    const TRANSITION_MS = 450;
    // Parallax offsets: how much each layer shifts during pan (in vw)
    const PARALLAX_BG = 0.3;
    const PARALLAX_MID = 0.7;

    let current = 0;
    let animating = false;

    function goTo(index: number) {
      if (animating) return;
      animating = true;

      // Circular navigation
      const next = ((index % TOTAL) + TOTAL) % TOTAL;
      const direction = index > current ? 1 : -1;

      // Apply blur during pan
      track.classList.add('is-panning');

      // Compute parallax offsets for each scene's layers
      const scenes = track.querySelectorAll<HTMLElement>('.sc-scene');
      scenes.forEach((scene, i) => {
        const bgLayer = scene.querySelector<HTMLElement>('.sc-bg');
        const midLayer = scene.querySelector<HTMLElement>('.sc-mid');
        // Offset relative to current position
        const offset = (i - next) * 100; // in vw
        if (bgLayer) bgLayer.style.transform = `translateX(${-offset * (1 - PARALLAX_BG)}px)`;
        if (midLayer) midLayer.style.transform = `translateX(${-offset * (1 - PARALLAX_MID)}px)`;
      });

      // Move track
      track.style.transform = `translateX(-${next * 100}vw)`;
      current = next;

      // Remove blur after transition ends
      setTimeout(() => {
        track.classList.remove('is-panning');
        animating = false;
      }, TRANSITION_MS + 50);
    }

    // Apply parallax with actual pixel offsets based on viewport
    function applyParallax(targetIndex: number) {
      const vw = window.innerWidth;
      const scenes = track.querySelectorAll<HTMLElement>('.sc-scene');
      scenes.forEach((scene, i) => {
        const bgLayer = scene.querySelector<HTMLElement>('.sc-bg');
        const midLayer = scene.querySelector<HTMLElement>('.sc-mid');
        const delta = (i - targetIndex);
        // Shift layers in opposite direction of travel to create depth
        const bgShift = delta * vw * (1 - PARALLAX_BG);
        const midShift = delta * vw * (1 - PARALLAX_MID);
        if (bgLayer) bgLayer.style.transform = `translateX(${bgShift}px)`;
        if (midLayer) midLayer.style.transform = `translateX(${midShift}px)`;
      });
    }

    function navigate(dir: number) {
      if (animating) return;
      const next = ((current + dir) % TOTAL + TOTAL) % TOTAL;

      animating = true;
      track.classList.add('is-panning');
      track.style.transform = `translateX(-${next * 100}vw)`;
      applyParallax(next);

      current = next;

      setTimeout(() => {
        track.classList.remove('is-panning');
        animating = false;
      }, TRANSITION_MS + 50);
    }

    // Button handlers
    prevBtn?.addEventListener('click', () => navigate(-1));
    nextBtn?.addEventListener('click', () => navigate(1));

    // Keyboard
    window.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); navigate(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); navigate(1); }
    });

    // Touch/swipe
    let touchStartX = 0;
    let touchStartY = 0;
    let swiping = false;

    wrapper.addEventListener('touchstart', (e: TouchEvent) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      swiping = false;
    }, { passive: true });

    wrapper.addEventListener('touchmove', (e: TouchEvent) => {
      const dx = e.touches[0].clientX - touchStartX;
      const dy = e.touches[0].clientY - touchStartY;
      // Only horizontal swipe
      if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 30) {
        swiping = true;
      }
    }, { passive: true });

    wrapper.addEventListener('touchend', () => {
      if (!swiping) return;
      const dx = touchStartX - (event as TouchEvent)?.changedTouches?.[0]?.clientX ?? 0;
      // Threshold reached during move, check final position
      if (Math.abs(dx) > 50) {
        navigate(dx > 0 ? 1 : -1);
      }
      swiping = false;
    });

    // Initial parallax state
    applyParallax(0);
  }
</script>
