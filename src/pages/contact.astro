---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — n0pics"
  description="Contactez Tom Mertens — n0pics. Une idée, un besoin&nbsp;? Écrivez-moi directement."
  noFooter
>
  <section class="contact">
    <div class="contact-card">

      <!-- Panneau gauche : formulaire -->
      <div class="contact-form-panel">
        <h1 class="contact-title" data-i18n="contact.title">Parlons de votre projet</h1>

        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <label class="field">
              <span class="sr-only" data-i18n="contact.form.fullname">Nom complet</span>
              <input type="text" name="fullname" autocomplete="name" required
                placeholder="Nom complet" data-i18n-placeholder="contact.form.fullname" />
            </label>
            <label class="field">
              <span class="sr-only" data-i18n="contact.form.email">Email</span>
              <input type="email" name="email" autocomplete="email" required
                placeholder="Email" data-i18n-placeholder="contact.form.email" />
            </label>
          </div>

          <label class="field">
            <span class="sr-only" data-i18n="contact.form.phone">Téléphone</span>
            <input type="tel" name="phone" autocomplete="tel"
              placeholder="Téléphone" data-i18n-placeholder="contact.form.phone" />
          </label>

          <label class="field">
            <span class="sr-only" data-i18n="contact.form.message">Message</span>
            <textarea name="message" rows="4" required
              placeholder="Message" data-i18n-placeholder="contact.form.message"></textarea>
          </label>

          <button type="submit" class="form-submit btn-glass" data-i18n="contact.form.submit">Envoyer</button>
        </form>
      </div>

      <!-- Panneau droit : coordonnées regroupées, centrées -->
      <aside class="contact-info">
        <div class="contact-info-content">
          <p class="contact-info-brand">n0pics<span>— Tom Mertens</span></p>

          <div class="contact-info-rule"></div>

          <ul class="contact-list">
            <li>
              <span class="contact-label" data-i18n="contact.email">Email</span>
              <a href="mailto:nopics.prod@gmail.com" class="contact-value">nopics.prod@gmail.com</a>
            </li>
            <li>
              <span class="contact-label" data-i18n="contact.location">Localisation</span>
              <span class="contact-value">Côte d'Azur, France</span>
            </li>
            <li>
              <span class="contact-label" data-i18n="contact.instagram">Instagram</span>
              <a
                href="https://www.instagram.com/n0pics_/"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-value contact-social"
                aria-label="Instagram n0pics_"
              >
                <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
                </svg>
                <span>@n0pics_</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7.5rem 1.5rem 3rem;
    color: #ffffff;
    font-family: var(--font-body);
  }

  .contact-card {
    width: 100%;
    max-width: 1180px;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 1.25rem;
  }

  /* Panneau gauche : aucun cadre, fond transparent */
  .contact-form-panel {
    background: transparent;
    border: none;
    padding: clamp(0.5rem, 2vw, 1.5rem) clamp(1rem, 3vw, 2.5rem) clamp(0.5rem, 2vw, 1.5rem) 0;
  }

  /* ---- Titre ---- */
  .contact-title {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0 0 2.5rem;
  }

  /* ---- Formulaire ---- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.9rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.9rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .field input,
  .field textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0;
    padding: 0.7rem 0;
    color: #ffffff;
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.3s ease;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.5);
    opacity: 1;
    transition: color 0.3s ease;
  }
  .field input:focus::placeholder,
  .field textarea:focus::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: rgba(255, 255, 255, 0.7);
  }

  .field textarea {
    resize: vertical;
    min-height: 3.5rem;
  }

  /* Alignement uniquement — le style vient de .btn-glass (global.css) */
  .form-submit {
    align-self: stretch;
    margin-top: 0.6rem;
    width: 100%;
    border-radius: 999px;
  }

  /* ---- Panneau infos : coordonnées regroupées, centrées ---- */
  .contact-info {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-info-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.4rem;
    padding: 2rem;
  }

  .contact-info-brand {
    font-family: 'Longa Iberica', Georgia, serif;
    font-size: clamp(1.8rem, 3.2vw, 2.5rem);
    line-height: 1;
    margin: 0;
    color: #ffffff;
  }
  .contact-info-brand span {
    display: block;
    margin-top: 0.8rem;
    font-family: var(--font-body);
    font-size: 0.62rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .contact-info-rule {
    width: 48px;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.8rem;
  }
  .contact-list li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.45rem;
  }
  .contact-label {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .contact-value {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  a.contact-value:hover { color: #ffffff; }

  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 860px) {
    .contact-card {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .contact-info-content {
      padding-top: 1rem;
    }
  }

  @media (max-width: 520px) {
    .form-row { grid-template-columns: 1fr; }
    .contact { padding-top: 6.5rem; }
  }
</style>

<script>
  // Le formulaire est un placeholder : branchez votre propre service
  // (Web3Forms, Formspree, une API, etc.) en définissant `action`/`method`
  // sur le <form>, ou en gérant l'envoi ici.
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    alert('Formulaire de démonstration — connectez votre service d\'envoi pour le rendre fonctionnel.');
  });
</script>
