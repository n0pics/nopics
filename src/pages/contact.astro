---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact — n0pics"
  description="Contactez Tom Mertens — n0pics. Une idée, un besoin&nbsp;? Écrivez-moi directement."
  noFooter
>
  <section class="contact">
    <div class="contact-card">

      <!-- Panneau gauche : formulaire -->
      <div class="contact-form-panel">
        <h1 class="contact-title" data-i18n="contact.title">Donnons forme à vos idées</h1>

        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <label class="field">
              <span class="sr-only" data-i18n="contact.form.fullname">Nom complet</span>
              <input type="text" name="fullname" autocomplete="name" required
                placeholder="Nom complet" data-i18n-placeholder="contact.form.fullname" />
            </label>
            <label class="field">
              <span class="sr-only" data-i18n="contact.form.email">Email</span>
              <input type="email" name="email" autocomplete="email" required
                placeholder="Email" data-i18n-placeholder="contact.form.email" />
            </label>
          </div>

          <label class="field">
            <span class="sr-only" data-i18n="contact.form.phone">Téléphone</span>
            <input type="tel" name="phone" autocomplete="tel"
              placeholder="Téléphone" data-i18n-placeholder="contact.form.phone" />
          </label>

          <label class="field">
            <span class="sr-only" data-i18n="contact.form.message">Message</span>
            <textarea name="message" rows="4" required
              placeholder="Message" data-i18n-placeholder="contact.form.message"></textarea>
          </label>

          <!-- Anti-spam : champ piège caché (rempli uniquement par les bots) -->
          <input type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" class="form-honey" />

          <button type="submit" class="form-submit btn-glass" data-i18n="contact.form.submit">Envoyer</button>
          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <!-- Panneau droit : coordonnées regroupées, centrées -->
      <aside class="contact-info">
        <div class="contact-info-content">
          <div class="contact-status">
            <span class="status-dot" aria-hidden="true"></span>
            <span data-i18n="contact.status">Disponible pour de nouveaux projets</span>
          </div>

          <p class="contact-info-brand">n0pics<span>Tom Mertens</span></p>

          <div class="contact-info-rule"></div>

          <ul class="contact-list">
            <li>
              <span class="contact-label" data-i18n="contact.email">Email</span>
              <button
                type="button"
                class="contact-value contact-copy"
                data-copy="nopics.prod@gmail.com"
                aria-label="Copier l'email"
              >
                <span class="copy-text">nopics.prod@gmail.com</span>
                <span class="copy-feedback" aria-hidden="true"><span data-i18n="contact.copied">Copié</span> ✓</span>
              </button>
            </li>
            <li>
              <span class="contact-label" data-i18n="contact.location">Localisation</span>
              <span class="contact-value">Côte d'Azur, France</span>
            </li>
            <li>
              <span class="contact-label" data-i18n="contact.instagram">Instagram</span>
              <a
                href="https://www.instagram.com/n0pics_/"
                target="_blank"
                rel="noopener noreferrer"
                class="contact-value contact-social"
                aria-label="Instagram n0pics_"
              >
                <span>@n0pics_</span>
              </a>
            </li>
          </ul>
        </div>
      </aside>

    </div>
  </section>
</BaseLayout>

<style>
  .contact {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 7.5rem 1.5rem 3rem;
    color: #ffffff;
    font-family: var(--font-body);
  }

  .contact-card {
    width: 100%;
    max-width: 1060px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: center;
  }

  /* Panneau gauche : aucun cadre, fond transparent */
  .contact-form-panel {
    background: transparent;
    border: none;
    padding: 0;
  }

  /* ---- Titre ---- */
  .contact-title {
    font-size: clamp(2.5rem, 5.5vw, 4.25rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.04;
    margin: 0 0 3.2rem;
  }

  /* ---- Formulaire ---- */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 2.6rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.6rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .field input,
  .field textarea {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 0;
    padding: 1.1rem 0;
    color: #ffffff;
    font-family: inherit;
    font-size: 1.15rem;
    transition: border-color 0.3s ease;
  }

  .field input::placeholder,
  .field textarea::placeholder {
    color: rgba(255, 255, 255, 0.5);
    opacity: 1;
    transition: color 0.3s ease;
  }
  .field input:focus::placeholder,
  .field textarea:focus::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-bottom-color: rgba(255, 255, 255, 0.7);
  }

  .field textarea {
    resize: vertical;
    min-height: 3.5rem;
  }

  /* Alignement uniquement — le style vient de .btn-glass (global.css) */
  .form-submit {
    align-self: stretch;
    margin-top: 1rem;
    width: 100%;
    border-radius: 999px;
    font-size: 0.82rem;
    padding-top: 1.15rem;
    padding-bottom: 1.15rem;
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: progress;
  }

  /* Champ anti-spam : invisible et hors layout */
  .form-honey {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
  }

  /* Message de statut sous le bouton (succès / erreur) */
  .form-status {
    margin: -1.6rem 0 0;
    min-height: 1.3em;
    font-size: 0.92rem;
    line-height: 1.5;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .form-status.is-visible { opacity: 1; }
  .form-status.is-success { color: #3ad17e; }
  .form-status.is-error { color: #ff8a8a; }

  /* ---- Panneau infos : coordonnées regroupées, centrées ---- */
  .contact-info {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .contact-info-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 2.9rem;
    padding: 2rem;
  }

  .contact-info-brand {
    font-family: 'Longa Iberica', Georgia, serif;
    font-size: clamp(2.2rem, 3.8vw, 3.1rem);
    line-height: 1;
    margin: 0;
    color: #ffffff;
  }
  .contact-info-brand span {
    display: block;
    margin-top: 0.9rem;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .contact-info-rule {
    width: 64px;
    height: 1px;
    background: rgba(255, 255, 255, 0.18);
  }

  /* Pastille de disponibilité (point qui pulse) */
  .contact-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.85rem 0.35rem 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.025);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }
  .status-dot {
    position: relative;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #3ad17e;
    flex-shrink: 0;
  }
  .status-dot::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #3ad17e;
    animation: status-pulse 2.2s ease-out infinite;
  }
  @keyframes status-pulse {
    0%   { transform: scale(1);   opacity: 0.7; }
    70%  { transform: scale(2.6); opacity: 0; }
    100% { transform: scale(2.6); opacity: 0; }
  }

  /* Email copiable au clic */
  .contact-copy {
    position: relative;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    font-family: inherit;
  }
  .contact-copy .copy-text {
    transition: opacity 0.25s ease;
  }
  .contact-copy .copy-feedback {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #3ad17e;
    opacity: 0;
    transition: opacity 0.25s ease;
    pointer-events: none;
  }
  .contact-copy.copied .copy-text { opacity: 0; }
  .contact-copy.copied .copy-feedback { opacity: 1; }

  @media (prefers-reduced-motion: reduce) {
    .status-dot::after { animation: none; }
  }

  .contact-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2.3rem;
  }
  .contact-list li {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.55rem;
  }
  .contact-label {
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }
  .contact-value {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  a.contact-value:hover { color: #ffffff; }

  .contact-social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }

  /* ---- Responsive ---- */
  @media (max-width: 860px) {
    .contact-card {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .contact-info-content {
      padding-top: 1rem;
    }
  }

  @media (max-width: 520px) {
    .form-row { grid-template-columns: 1fr; }
    .contact { padding-top: 6.5rem; }
  }
</style>

<script>
  // ============================================================
  // Envoi du formulaire via FormSubmit (service sans backend).
  // Les messages arrivent à l'adresse ci-dessous. Requête AJAX : on reste
  // sur la page et on affiche un statut de succès / d'erreur.
  // ⚠️ Le tout premier envoi déclenche un mail d'activation FormSubmit :
  //    clique le lien à l'intérieur UNE fois pour activer la réception.
  // ============================================================
  const CONTACT_ENDPOINT = 'https://formsubmit.co/ajax/nopics.prod@gmail.com';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const statusEl = document.getElementById('form-status');
  const submitBtn = form?.querySelector<HTMLButtonElement>('.form-submit') ?? null;

  const lang = (): 'fr' | 'en' => (document.documentElement.lang === 'en' ? 'en' : 'fr');

  const T = {
    sending: { fr: 'Envoi…', en: 'Sending…' },
    submit: { fr: 'Envoyer', en: 'Send' },
    success: {
      fr: 'Message envoyé ✓ Merci, je vous réponds très vite.',
      en: "Message sent ✓ Thanks, I'll get back to you soon.",
    },
    error: {
      fr: "Oups, l'envoi a échoué. Réessayez ou écrivez-moi à nopics.prod@gmail.com.",
      en: 'Oops, sending failed. Please retry or email me at nopics.prod@gmail.com.',
    },
  } as const;

  function showStatus(kind: 'success' | 'error', text: string) {
    if (!statusEl) return;
    statusEl.textContent = text;
    statusEl.classList.remove('is-success', 'is-error');
    statusEl.classList.add('is-visible', kind === 'success' ? 'is-success' : 'is-error');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!form) return;
    const l = lang();

    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = T.sending[l]; }
    statusEl?.classList.remove('is-visible', 'is-success', 'is-error');

    const data = new FormData(form);
    data.append('_subject', 'Nouveau message depuis n0pics.com');
    data.append('_template', 'table');
    data.append('_captcha', 'false');

    try {
      const res = await fetch(CONTACT_ENDPOINT, {
        method: 'POST',
        headers: { Accept: 'application/json' },
        body: data,
      });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      form.reset();
      showStatus('success', T.success[l]);
    } catch {
      showStatus('error', T.error[l]);
    } finally {
      if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = T.submit[l]; }
    }
  });

  // Email copiable au clic, avec retour visuel « Copié ✓ »
  document.querySelectorAll<HTMLButtonElement>('.contact-copy').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy ?? '';
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand('copy'); } catch {}
        ta.remove();
      }
      btn.classList.add('copied');
      window.setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>
