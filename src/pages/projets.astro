---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projets } from '@/data/projets';
---

<BaseLayout
  title="Projets — n0pics"
  description="Sélection de projets de Tom Mertens — n0pics."
  noFooter
>
  <section class="projets-page">
    <header class="projets-head">
      <p class="projets-eyebrow">Sélection</p>
      <h1 class="projets-title">Projets</h1>
      <p class="projets-intro">
        Une sélection de projets — direction artistique, identité et création de
        visuels. Remplace ce texte par ta propre introduction.
      </p>
    </header>

    <div class="projets-grid">
      {projets.map((p) =>
        p.comingSoon ? (
          <div class="projet-card is-soon" aria-hidden="true">
            <div class="projet-cover projet-cover--placeholder"></div>
            <div class="projet-meta">
              <div class="projet-meta-top">
                <h2 class="projet-name">{p.title}</h2>
              </div>
              <p class="projet-comment">Bientôt disponible</p>
            </div>
          </div>
        ) : (
          <a href={`/projets/${p.slug}`} class="projet-card">
            <div class="projet-cover">
              <img src={p.cover} alt={p.title} loading="lazy" decoding="async" />
            </div>
            <div class="projet-meta">
              <div class="projet-meta-top">
                <h2 class="projet-name">{p.title}</h2>
                <span class="projet-date">{p.date}</span>
              </div>
              {p.comment && <p class="projet-comment">{p.comment}</p>}
            </div>
          </a>
        )
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .projets-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 9rem 1.5rem 6rem;
    color: var(--color-text);
  }

  .projets-head {
    max-width: 640px;
    margin-bottom: 3.5rem;
  }
  .projets-eyebrow {
    font-size: 0.7rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.9rem;
  }
  .projets-title {
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0 0 1.1rem;
  }
  .projets-intro {
    color: var(--color-text-muted);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
    margin: 0;
  }

  /* ---- Grille de projets ---- */
  .projets-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.75rem 2rem;
  }

  .projet-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .projet-cover {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-bg-soft);
    border-radius: 3px;
  }
  .projet-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .projet-card:hover .projet-cover img {
    transform: scale(1.04);
  }
  .projet-cover--placeholder {
    background: radial-gradient(120% 120% at 50% 30%, #1a1a1f 0%, #0c0c0e 60%, #070708 100%);
  }

  .projet-meta {
    padding-top: 1.1rem;
  }
  .projet-meta-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .projet-name {
    font-size: clamp(1.1rem, 1.6vw, 1.4rem);
    font-weight: 700;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    margin: 0;
  }
  .projet-date {
    font-size: 0.8rem;
    color: var(--color-text-faint);
    flex-shrink: 0;
    letter-spacing: 0.05em;
  }
  .projet-comment {
    margin: 0.6rem 0 0;
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    max-width: 42ch;
  }

  .is-soon {
    cursor: default;
    opacity: 0.5;
  }

  @media (max-width: 760px) {
    .projets-page {
      padding-top: 7rem;
    }
    .projets-grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }
</style>
