---
import BaseLayout from '@/layouts/BaseLayout.astro';
const items = [
  {
    title: 'SERVICE 01',
    i18nKey: 'svc.realisation-video',
    descKey: 'svc.desc.realisation-video',
    desc: 'Décrivez votre premier service et la valeur que vous apportez à vos clients.',
  },
  {
    title: 'SERVICE 02',
    i18nKey: 'svc.photographie',
    descKey: 'svc.desc.photographie',
    desc: 'Décrivez votre deuxième service et la valeur que vous apportez à vos clients.',
  },
  {
    title: 'SERVICE 03',
    i18nKey: 'svc.prise-de-vue-aerienne',
    descKey: 'svc.desc.prise-de-vue-aerienne',
    desc: 'Décrivez votre troisième service et la valeur que vous apportez à vos clients.',
  },
  {
    title: 'SERVICE 04',
    i18nKey: 'svc.post-prod',
    descKey: 'svc.desc.post-prod',
    desc: 'Décrivez votre quatrième service et la valeur que vous apportez à vos clients.',
  },
  {
    title: 'SERVICE 05',
    i18nKey: 'svc.ecriture',
    descKey: 'svc.desc.ecriture',
    desc: 'Décrivez votre cinquième service et la valeur que vous apportez à vos clients.',
  },
];
---

<BaseLayout
  title="Services — Votre Portfolio"
  description="Présentez vos services. Remplacez cette description par la vôtre."
  noFooter
  theme="light"
>

  <section class="services-section">
    <h1 class="sr-only">Services — Réalisation vidéo, photographie, drone, post-production</h1>
    <div class="services-list">
      {items.map((item, i) => (
        <div class="service-block" style={`--i: ${i}`}>
          <button
            class="service-name"
            data-i18n={item.i18nKey}
            aria-expanded="false"
          >
            {item.title}
          </button>
          <div class="service-desc-wrap">
            <p class="service-desc" data-i18n-html={item.descKey} set:html={item.desc}>
            </p>
          </div>
        </div>
      ))}
      <span
        class="service-name service-more"
        style="--i: 5"
        data-i18n="svc.more"
      >
        + ENCORE
      </span>
    </div>
  </section>

</BaseLayout>

<style>
  /* ============================================================
     SERVICES PAGE — Outlined text list with expand on click
     White background, outlined/stroked text, fill on hover
     ============================================================ */

  .services-section {
    width: 100vw;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #ffffff;
    padding: 6rem 2rem;
  }

  .services-list {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.15em;
  }

  /* ---- Service block (title + description) ---- */
  .service-block {
    display: flex;
    flex-direction: column;
    align-items: center;

    /* Entrance animation */
    opacity: 0;
    transform: translateY(30px);
    animation: service-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 0.08s + 0.15s);
  }

  /* ---- Outlined text effect ---- */
  .service-name {
    font-family: var(--font-body);
    font-size: clamp(1.8rem, 5.5vw, 4.5rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    line-height: 1.15;
    display: block;
    padding: 0.1em 0.25em;
    cursor: pointer;
    background: none;
    border: none;

    /* Outlined / hollow text */
    color: #191919;
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 1.5px #191919;

    /* Hover transition */
    transition: -webkit-text-fill-color 0.25s ease,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .service-name:hover {
      -webkit-text-fill-color: #191919;
    }
  }

  /* Active state — title lifts up + stays filled */
  .service-block.is-open .service-name {
    -webkit-text-fill-color: #191919;
    transform: translateY(-0.15em);
  }

  /* ---- Description wrapper — collapsed by default ---- */
  .service-desc-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
  }

  .service-block.is-open .service-desc-wrap {
    grid-template-rows: 1fr;
  }

  .service-desc {
    min-height: 0;
    font-family: var(--font-body);
    font-size: clamp(0.9rem, 1.4vw, 1.15rem);
    font-weight: 500;
    color: #191919;
    line-height: 1.7;
    text-align: center;
    padding: 0 1rem;
    opacity: 0;
    transform: translateY(-0.5rem);
    transition: opacity 0.4s ease 0.1s,
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1) 0.1s;
  }

  .service-block.is-open .service-desc {
    opacity: 1;
    transform: translateY(0);
    padding-bottom: 0.75em;
  }

  /* ---- "+ ENCORE" subtle variant ---- */
  .service-more {
    margin-top: 0.3em;
    font-size: clamp(1.2rem, 3vw, 2.5rem);
    font-weight: 600;
    -webkit-text-stroke-width: 1px;
    cursor: default;

    /* Entrance animation */
    opacity: 0;
    transform: translateY(30px);
    animation: service-enter 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: calc(var(--i) * 0.08s + 0.15s);
  }

  /* ---- Entrance animation ---- */
  @keyframes service-enter {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .services-section {
      padding: 5rem 1rem;
    }

    .service-name {
      -webkit-text-stroke-width: 1px;
    }

    .service-more {
      -webkit-text-stroke-width: 0.75px;
    }

    .service-desc {
      max-width: 100%;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  // ============================================================
  // Services — toggle description on click
  // ============================================================
  const blocks = document.querySelectorAll<HTMLElement>('.service-block');

  blocks.forEach((block) => {
    const btn = block.querySelector('.service-name') as HTMLButtonElement;

    btn?.addEventListener('click', () => {
      const isOpen = block.classList.contains('is-open');

      // Close all others
      blocks.forEach((b) => {
        b.classList.remove('is-open');
        const otherBtn = b.querySelector('.service-name');
        otherBtn?.setAttribute('aria-expanded', 'false');
      });

      // Toggle current
      if (!isOpen) {
        block.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
