---
import BaseLayout from '@/layouts/BaseLayout.astro';

// Les textes (FR par défaut ci-dessous) sont traduits via i18n :
// data-i18n="svc.<key>.title" / "svc.<key>.desc" (voir src/i18n/translations.ts).
const services = [
  {
    key: 'digital',
    title: 'Design digital',
    desc: 'Création de visuels adaptés aux réseaux sociaux et aux écrans, pensés pour capter l’attention et renforcer votre présence en ligne.',
    items: ['Visuels réseaux sociaux', 'Bannières web', 'Templates'],
  },
  {
    key: 'retouche',
    title: 'Retouche photo / Post-production',
    desc: 'Amélioration des images pour leur donner un rendu plus propre, cohérent et impactant, en renforçant leur style et leur ambiance générale.',
    items: ['Color grading', 'Harmonisation', 'Recadrage / composition'],
  },
  {
    key: 'print',
    title: 'Design d’impression',
    desc: 'Conception de supports imprimés clairs et impactants, alliant lisibilité, esthétique et contraintes techniques d’impression.',
    items: ['Affiches / posters', 'Cartes de visite'],
  },
  {
    key: 'illustration',
    title: 'Illustration & assets graphiques',
    desc: 'Création d’éléments visuels sur mesure pour enrichir votre identité et rendre vos supports plus distinctifs et mémorables.',
    items: ['Compositions visuelles', 'Collages', 'Photomontage'],
  },
];
---

<BaseLayout
  title="Services — n0pics"
  description="Les services de Tom Mertens — n0pics : direction artistique, identité visuelle, création de visuels."
  noFooter
>
  <section class="services">
    <h1 class="sr-only">Services — Tom Mertens, n0pics</h1>

    <ul class="svc-list">
      {services.map((s) => (
        <li class="svc-item">
          <button class="svc-head" type="button" aria-expanded="false">
            <span class="svc-title" data-i18n={`svc.${s.key}.title`}>{s.title}</span>
            <span class="svc-toggle" aria-hidden="true"></span>
          </button>
          <div class="svc-panel">
            <div class="svc-panel-inner">
              <div class="svc-panel-content">
                <p class="svc-desc" data-i18n={`svc.${s.key}.desc`}>{s.desc}</p>
                {s.items.length > 0 && (
                  <p class="svc-meta" data-i18n={`svc.${s.key}.items`}>{s.items.join(' · ')}</p>
                )}
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .services {
    min-height: 100vh;
    max-width: 1040px;
    margin: 0 auto;
    padding: 8rem 1.5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    color: var(--color-text);
  }

  /* ---- Liste accordéon ---- */
  .svc-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .svc-item {
    border-top: 1px solid var(--color-border-mid, rgba(255, 255, 255, 0.12));
  }
  .svc-item:last-child {
    border-bottom: 1px solid var(--color-border-mid, rgba(255, 255, 255, 0.12));
  }

  /* En-tête de ligne (cliquable) */
  .svc-head {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    gap: 1.5rem;
    width: 100%;
    padding: clamp(1.15rem, 2.6vw, 1.8rem) clamp(1rem, 2.5vw, 1.5rem);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--color-text);
    font-family: var(--font-display);
    transition: color 0.6s ease;
  }
  /* Balayage de remplissage au survol */
  .svc-head::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: var(--color-text);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (hover: hover) and (pointer: fine) {
    .svc-head:hover {
      color: #050505;
    }
    .svc-head:hover::before {
      transform: scaleX(1);
    }
  }

  .svc-title {
    flex: 1;
    min-width: 0;
    font-size: clamp(1.55rem, 3.6vw, 2.9rem);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.15;
    color: inherit;
  }

  /* Indicateur + / − */
  .svc-toggle {
    position: relative;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }
  .svc-toggle::before,
  .svc-toggle::after {
    content: "";
    position: absolute;
    background: currentColor;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s ease;
  }
  .svc-toggle::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }
  .svc-toggle::after {
    left: 50%;
    top: 0;
    width: 1.5px;
    height: 100%;
    transform: translateX(-50%);
  }
  .svc-item.is-open .svc-toggle::after {
    transform: translateX(-50%) scaleY(0);
    opacity: 0;
  }

  /* Panneau dépliant (transition fluide via grid) */
  .svc-panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .svc-item.is-open .svc-panel {
    grid-template-rows: 1fr;
  }
  .svc-panel-inner {
    min-height: 0;
    overflow: hidden;
  }
  .svc-panel-content {
    padding-bottom: clamp(1.5rem, 3vw, 2rem);
  }
  .svc-desc {
    max-width: 78ch;
    margin: 0;
    padding: 0 clamp(1rem, 2.5vw, 1.5rem);
    font-family: var(--font-body);
    font-size: clamp(0.98rem, 1.25vw, 1.12rem);
    font-weight: 300;
    line-height: 1.8;
    color: var(--color-text-muted);
  }
  /* Ligne de prestations (mots-clés séparés par des points médians) */
  .svc-meta {
    margin: 1.1rem 0 0;
    padding: 0 clamp(1rem, 2.5vw, 1.5rem);
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-text-faint, rgba(242, 240, 235, 0.4));
  }

  @media (max-width: 600px) {
    .services {
      padding-top: 7.5rem;
    }
  }
</style>

<script>
  const items = document.querySelectorAll<HTMLElement>('.svc-item');

  items.forEach((item) => {
    const head = item.querySelector<HTMLButtonElement>('.svc-head');
    head?.addEventListener('click', () => {
      const isOpen = item.classList.contains('is-open');

      // Ferme tous les autres (accordéon : un seul ouvert à la fois)
      items.forEach((other) => {
        other.classList.remove('is-open');
        other.querySelector('.svc-head')?.setAttribute('aria-expanded', 'false');
      });

      if (!isOpen) {
        item.classList.add('is-open');
        head.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
