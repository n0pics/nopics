---
import fs from 'node:fs';
import path from 'node:path';
import LandingLayout from '@/layouts/LandingLayout.astro';
import InfiniteGallery from '@/components/ui/3d-gallery-photography';

// Charge automatiquement toutes les images du dossier /public/images/accueil/.
// Pour changer les photos de l'accueil : ajoute/retire simplement des fichiers
// dans ce dossier (formats .jpg / .png / .webp).
const accueilDir = path.join(process.cwd(), 'public/images/accueil');
const galleryImages = fs
  .readdirSync(accueilDir)
  .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
  .map((f) => ({ src: `/images/accueil/${f}`, alt: '' }));

// Ordre aléatoire (Fisher-Yates), calculé à chaque chargement (dev) et au build.
for (let i = galleryImages.length - 1; i > 0; i--) {
  const j = Math.floor(Math.random() * (i + 1));
  [galleryImages[i], galleryImages[j]] = [galleryImages[j], galleryImages[i]];
}
---

<LandingLayout
  title="n0pics — Portfolio de Tom Mertens"
  description="Portfolio de Tom Mertens, graphic designer. n0pics — une sélection de projets et de créations."
>
  <section class="landing-hero">
    <h1 class="sr-only">n0pics — Portfolio de Tom Mertens</h1>

    <!-- Galerie 3D plein écran (rendu navigateur uniquement : WebGL) -->
    <InfiniteGallery
      client:only="react"
      images={galleryImages}
      speed={1.2}
      visibleCount={18}
      className="hero-gallery-canvas"
    />

    <!-- Wordmark superposé -->
    <div class="hero-overlay">
      <a href="/" class="hero-logo">
        <span class="hero-logo-word">n0pics</span>
        <span class="hero-logo-sub" data-i18n="landing.production">STUDIO</span>
      </a>
      <span class="hero-logo-author" data-i18n="landing.portfolio">Portfolio de Tom Mertens</span>
    </div>

    <!-- Porte d'entrée discrète vers les projets -->
    <a href="/projets" class="hero-cta" aria-label="Voir les projets">
      <svg viewBox="0 0 44 12" width="44" height="12" aria-hidden="true" focusable="false">
        <path d="M1 6 H41 M34 1 L41 6 L34 11" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
  </section>
</LandingLayout>

<!-- La galerie est rendue par React : son <div> ne reçoit pas les styles
     "scoped" d'Astro, on la cible donc en global. -->
<style is:global>
  .hero-gallery-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .hero-gallery-canvas canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    touch-action: none;
  }
</style>

<style>
  .landing-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #050505;
  }

  /* CTA discret — flèche en bas à droite vers les projets */
  .hero-cta {
    position: absolute;
    bottom: 2.25rem;
    right: 2.5rem;
    z-index: 25;
    display: inline-flex;
    align-items: center;
    color: rgba(255, 255, 255, 0.55);
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.55));
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    animation: hero-fade 1s cubic-bezier(0.16, 1, 0.3, 1) 0.5s both;
  }

  .hero-cta:hover {
    color: #ffffff;
    transform: translateX(5px);
  }

  /* ---- Mobile ---- */
  @media (max-width: 600px) {
    .hero-cta {
      bottom: 1.5rem;
      right: 1.5rem;
    }
  }

  /* ---- Wordmark superposé, centré ---- */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    mix-blend-mode: difference;
  }

  .hero-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-decoration: none;
    pointer-events: auto;
    animation: hero-fade 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-logo-word {
    font-family: 'Longa Iberica', Georgia, serif;
    font-size: clamp(4.5rem, 18vw, 14rem);
    font-weight: normal;
    letter-spacing: 0;
    text-transform: none;
    color: #ffffff;
    line-height: 1;
  }

  .hero-logo-sub {
    font-family: var(--font-body);
    font-size: clamp(0.6rem, 1.5vw, 1.15rem);
    font-weight: 300;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    text-indent: 0.5em;
    margin-top: 1.7rem;
  }

  .hero-logo-author {
    margin-top: 1.5rem;
    font-family: var(--font-body);
    font-size: clamp(0.6rem, 1.5vw, 1.1rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
  }

  @keyframes hero-fade {
    from { opacity: 0; transform: translateY(1rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
