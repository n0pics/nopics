---
import LandingLayout from '@/layouts/LandingLayout.astro';
import InfiniteGallery from '@/components/ui/3d-gallery-photography';

// Galerie d'images de démonstration (Unsplash) — remplace ces URL par tes propres
// visuels (ex. des fichiers déposés dans /public/images/...).
const galleryImages = [
  { src: 'https://images.unsplash.com/photo-1741332966416-414d8a5b8887?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 1' },
  { src: 'https://images.unsplash.com/photo-1754769440490-2eb64d715775?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 2' },
  { src: 'https://images.unsplash.com/photo-1758640920659-0bb864175983?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 3' },
  { src: 'https://plus.unsplash.com/premium_photo-1758367454070-731d3cc11774?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 4' },
  { src: 'https://images.unsplash.com/photo-1746023841657-e5cd7cc90d2c?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 5' },
  { src: 'https://images.unsplash.com/photo-1741715661559-6149723ea89a?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 6' },
  { src: 'https://images.unsplash.com/photo-1725878746053-407492aa4034?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 7' },
  { src: 'https://images.unsplash.com/photo-1752588975168-d2d7965a6d64?w=1200&auto=format&fit=crop&q=70', alt: 'Visuel 8' },
];
---

<LandingLayout
  title="Votre Portfolio — Accueil"
  description="Galerie 3D immersive. Remplacez cette description par la vôtre."
>
  <section class="landing-hero">
    <h1 class="sr-only">Votre Portfolio</h1>

    <!-- Galerie 3D plein écran (rendu navigateur uniquement : WebGL) -->
    <InfiniteGallery
      client:only="react"
      images={galleryImages}
      speed={1.2}
      visibleCount={12}
      className="hero-gallery-canvas"
    />

    <!-- Wordmark superposé -->
    <div class="hero-overlay">
      <a href="/" class="hero-logo">
        <span class="hero-logo-word">STUDIO</span>
        <span class="hero-logo-sub" data-i18n="landing.production">PORTFOLIO</span>
      </a>
      <span class="hero-logo-author" data-i18n="landing.portfolio">Portfolio de Votre Nom</span>
    </div>
  </section>
</LandingLayout>

<!-- La galerie est rendue par React : son <div> ne reçoit pas les styles
     "scoped" d'Astro, on la cible donc en global. -->
<style is:global>
  .hero-gallery-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }
  .hero-gallery-canvas canvas {
    display: block;
    width: 100% !important;
    height: 100% !important;
    touch-action: none;
  }
</style>

<style>
  .landing-hero {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: #050505;
  }

  /* ---- Wordmark superposé, centré ---- */
  .hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    mix-blend-mode: difference;
  }

  .hero-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    text-decoration: none;
    pointer-events: auto;
    animation: hero-fade 1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  .hero-logo-word {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(2.5rem, 9vw, 7rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    line-height: 1;
  }

  .hero-logo-sub {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(0.6rem, 1.5vw, 1.15rem);
    font-weight: 300;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
    text-indent: 0.5em;
    margin-top: -0.4rem;
  }

  .hero-logo-author {
    margin-top: 0.7rem;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(0.6rem, 1.5vw, 1.1rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    text-align: center;
  }

  @keyframes hero-fade {
    from { opacity: 0; transform: translateY(1rem); }
    to   { opacity: 1; transform: translateY(0); }
  }
</style>
