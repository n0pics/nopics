---
import LandingLayout from '@/layouts/LandingLayout.astro';
---

<LandingLayout
  title="Votre Portfolio — Accueil"
  description="Page d'accueil de votre portfolio. Remplacez cette description par la vôtre."
>

  <!-- ================================================================
       SMOOTH SCROLL HERO
       Clip-path qui s'ouvre au scroll + parallax zoom background
       Déposez votre vidéo de fond dans /public/videos/hero.mp4
       ================================================================ -->
  <div class="hero-scroll-container" id="hero-scroll">
    <h1 class="sr-only">Votre Portfolio</h1>

    <!-- Vidéo de fond avec clip-path animé (placeholder : ajoutez /public/videos/hero.mp4) -->
    <div class="hero-sticky" id="hero-sticky">
      <video
        class="hero-video"
        id="hero-video"
        src="/videos/hero.mp4"
        autoplay
        loop
        muted
        playsinline
      ></video>
    </div>
  </div>

  <!-- Logo centré + bouton — superposé, fixe pendant le scroll -->
  <div class="hero-overlay" id="hero-overlay">
    <!-- Wordmark (remplacez par votre logo si besoin) -->
    <a href="/" class="hero-logo" id="hero-logo-link">
      <span class="hero-logo-word">STUDIO</span>
      <span class="hero-logo-sub" data-i18n="landing.production">PORTFOLIO</span>
    </a>
    <span class="hero-logo-author" data-i18n="landing.portfolio">Portfolio de Votre Nom</span>
  </div>

</LandingLayout>

<style>
  /* ============================================================
     SMOOTH SCROLL HERO — pure CSS/JS adaptation
     Scroll-driven clip-path expansion + zoom parallax
     ============================================================ */

  /* Container — single viewport height, no scroll needed */
  .hero-scroll-container {
    position: relative;
    width: 100%;
    height: 100vh;
    background-color: #050505;
    overflow: hidden;
  }

  /* Video panel — fills the viewport */
  .hero-sticky {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    /* Fond de repli (dégradé) visible tant qu'aucune vidéo n'est fournie */
    background: radial-gradient(120% 120% at 50% 30%, #1a1a1f 0%, #0a0a0c 55%, #050505 100%);
    overflow: hidden;
    /* Clip-path initial : petit rectangle centré (25% inset) */
    clip-path: polygon(25% 25%, 75% 25%, 75% 75%, 25% 75%);
    will-change: clip-path;
  }

  /* Vidéo de fond */
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* Zoom initial léger via scale */
    transform: scale(1.15);
    transform-origin: center center;
    will-change: transform;
  }

  /* ============================================================
     OVERLAY — Logo + Scroll hint + Bouton
     Fixe au centre pendant toute la durée du scroll
     ============================================================ */
  .hero-overlay {
    position: fixed;
    inset: 0;
    z-index: 20;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  /* Logo centré */
  .hero-logo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    animation: fade-in 0.8s cubic-bezier(0.16, 1, 0.3, 1) both;
    text-decoration: none;
    pointer-events: all;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .hero-logo:hover {
    opacity: 0.8;
  }

  .hero-logo-word {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(2.5rem, 9vw, 7rem);
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #ffffff;
    opacity: 0.95;
    line-height: 1;
    text-shadow: 0 4px 24px rgba(0, 0, 0, 0.6);
  }

  .hero-logo-sub {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(0.6rem, 1.5vw, 1.15rem);
    font-weight: 300;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: rgba(250, 250, 250, 0.7);
    text-indent: 0.5em;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
    margin-top: -0.6rem;
  }

  .hero-logo-author {
    margin-top: 0.6rem;
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: clamp(0.6rem, 1.5vw, 1.15rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.55);
    text-align: center;
  }


  /* ============================================================
     Animations
     ============================================================ */
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(1rem); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ============================================================
     Responsive
     ============================================================ */
</style>

<script>
  // === SmoothScrollHero — auto-animated clip-path + zoom ===
  const scrollContainer = document.getElementById('hero-scroll');
  const sticky = document.getElementById('hero-sticky');
  const heroVideo = document.getElementById('hero-video') as HTMLVideoElement | null;
  const overlay = document.getElementById('hero-overlay');
  const siteHeader = document.getElementById('site-header');

  // Hide header initially on landing page
  if (siteHeader) {
    siteHeader.style.opacity = '0';
    siteHeader.style.transition = 'opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
  }

  if (scrollContainer && sticky && overlay) {
    const INITIAL_CLIP = 25;
    const FINAL_CLIP_START = 75;

    // Animation config
    const OPEN_DURATION = 3500;   // ms — opening
    const CLOSE_DURATION = 1800;  // ms — closing (faster feels snappier)

    let progress = 0;
    let animStartTime: number | null = null;
    let animating = false;
    let direction: 'open' | 'close' = 'open';

    function lerp(start: number, end: number, t: number): number {
      return start + (end - start) * Math.max(0, Math.min(1, t));
    }

    function easeInOutCubic(t: number): number {
      return t < 0.5
        ? 4 * t * t * t
        : 1 - Math.pow(-2 * t + 2, 3) / 2;
    }

    function render() {
      const clipStart = lerp(INITIAL_CLIP, 0, progress);
      const clipEnd = lerp(FINAL_CLIP_START, 100, progress);
      sticky!.style.clipPath = `polygon(${clipStart}% ${clipStart}%, ${clipEnd}% ${clipStart}%, ${clipEnd}% ${clipEnd}%, ${clipStart}% ${clipEnd}%)`;

      const videoScale = lerp(1.15, 1.0, progress);
      if (heroVideo) heroVideo.style.transform = `scale(${videoScale})`;

      // Show header when animation is nearly complete
      if (siteHeader) {
        siteHeader.style.opacity = progress >= 0.85 ? '1' : '0';
      }
    }

    function animate(timestamp: number) {
      if (!animStartTime) animStartTime = timestamp;
      const elapsed = timestamp - animStartTime;

      if (direction === 'open') {
        const raw = Math.min(elapsed / OPEN_DURATION, 1);
        progress = easeInOutCubic(raw);
        if (raw >= 1) {
          progress = 1;
          animating = false;
        }
      } else {
        // close
        const raw = Math.min(elapsed / CLOSE_DURATION, 1);
        progress = 1 - easeInOutCubic(raw);
        if (raw >= 1) {
          progress = 0;
          animating = false;
          // Once closed, immediately re-open
          direction = 'open';
          animStartTime = null;
          animating = true;
          render();
          requestAnimationFrame(animate);
          return;
        }
      }

      render();

      if (animating) {
        requestAnimationFrame(animate);
      }
    }

    function startAnimation(dir: 'open' | 'close') {
      direction = dir;
      animStartTime = null;
      animating = true;
      requestAnimationFrame(animate);
    }

    // Ensure video loops at 30 seconds
    if (heroVideo) {
      const LOOP_AT = 30;
      heroVideo.play().catch(() => {});
      heroVideo.addEventListener('timeupdate', () => {
        if (heroVideo.currentTime >= LOOP_AT) {
          heroVideo.currentTime = 0;
        }
      });
      heroVideo.addEventListener('pause', () => {
        heroVideo.play().catch(() => {});
      });
      heroVideo.addEventListener('ended', () => {
        heroVideo.currentTime = 0;
        heroVideo.play().catch(() => {});
      });
    }

    // Logo click — close then re-open
    const logoLink = document.getElementById('hero-logo-link');
    if (logoLink) {
      logoLink.addEventListener('click', (e) => {
        e.preventDefault();
        if (animating) return; // ignore if already animating
        startAnimation('close');
      });
    }

    // Initial open animation
    render();
    startAnimation('open');
  }

</script>
