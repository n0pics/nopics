---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '@/layouts/BaseLayout.astro';
import BackToTop from '@/components/ui/BackToTop.astro';
import { projets, type Projet } from '@/data/projets';

export function getStaticPaths() {
  return projets
    .filter((p) => !p.comingSoon && !p.customPage)
    .map((p) => ({ params: { slug: p.slug }, props: { projet: p } }));
}

const { projet } = Astro.props as { projet: Projet };

// Build-time : charge toutes les photos du dossier du projet, puis les entrelace
// par "famille" (nom sans le numéro final) pour éviter deux photos qui se
// ressemblent côte à côte.
let images: string[] = [];
if (projet.galleryDir) {
  const dir = path.join(process.cwd(), 'public', projet.galleryDir);
  try {
    const files = fs
      .readdirSync(dir)
      .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
      .sort();

    const groups = new Map<string, string[]>();
    for (const f of files) {
      const key = f.replace(/\.[^.]+$/, '').replace(/-\d+$/, '');
      const arr = groups.get(key) ?? [];
      arr.push(f);
      groups.set(key, arr);
    }

    // Familles triées par taille décroissante, puis on prend une photo de
    // chaque famille à tour de rôle (round-robin).
    const groupList = [...groups.values()].sort((a, b) => b.length - a.length);
    const maxLen = Math.max(0, ...groupList.map((g) => g.length));
    const ordered: string[] = [];
    for (let r = 0; r < maxLen; r++) {
      for (const g of groupList) {
        if (g[r]) ordered.push(g[r]);
      }
    }

    images = ordered.map((f) => `/${projet.galleryDir}/${f}`);
  } catch {
    images = [];
  }
}

// Nombre de photos affichées avant le bouton « Voir plus »
const INITIAL = 12;

// Répartition en colonnes (round-robin) au build : chaque photo a une colonne
// fixe → « Voir plus » ajoute les suivantes en bas de leur colonne sans
// déplacer les autres (ordre statique). Le JS rebascule à 2 colonnes sur mobile.
const COLS = 3;
const galleryCols: { src: string; i: number }[][] = Array.from(
  { length: COLS },
  () => [],
);
images.forEach((src, i) => galleryCols[i % COLS].push({ src, i }));
---

<BaseLayout title={`${projet.title} — n0pics`} description={projet.comment} noFooter>
  <article class="projet-detail">
    <a href="/projets" class="detail-back" data-i18n="project.backLink">← Projets</a>

    <header class="detail-head">
      <div class="detail-head-main">
        {projet.category && (
          <p class="detail-cat" data-i18n={projet.i18n ? `project.${projet.i18n}.category` : undefined}>{projet.category}</p>
        )}
        <h1 class="detail-title">
          {projet.title}<span class="detail-year"> — {projet.date}</span>
        </h1>
        {projet.comment && (
          <p class="detail-comment" data-i18n={projet.i18n ? `project.${projet.i18n}.comment` : undefined}>{projet.comment}</p>
        )}
      </div>
      {projet.credit && (
        <p class="detail-credit">
          <span data-i18n="project.engagedBy">Engagé par</span> <span class="credit-handle">{projet.credit}</span>
        </p>
      )}
    </header>

    <div class="detail-gallery">
      {galleryCols.map((col) => (
        <div class="gallery-col">
          {col.map(({ src, i }) => (
            <img
              src={src}
              alt={projet.title}
              loading="lazy"
              decoding="async"
              data-i={i}
              class={i >= INITIAL ? 'is-extra' : undefined}
            />
          ))}
        </div>
      ))}
    </div>

    {images.length > INITIAL && (
      <div class="gallery-more-wrap">
        <button class="btn-glass" id="gallery-more" type="button" data-i18n="project.more">Voir plus</button>
      </div>
    )}
  </article>

  <!-- Lightbox : clic sur une photo = plein écran -->
  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <button class="lightbox-close" id="lightbox-close" type="button" aria-label="Fermer">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" aria-hidden="true">
        <path d="M5 5l14 14M19 5L5 19" />
      </svg>
    </button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>

  <BackToTop />
</BaseLayout>

<style>
  .projet-detail {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8rem 1.5rem 6rem;
    color: var(--color-text);
  }

  .detail-back {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.3s ease;
  }
  .detail-back:hover {
    color: var(--color-text);
  }

  .detail-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 2rem;
    margin-bottom: 3rem;
  }
  .detail-head-main {
    max-width: 680px;
  }
  .detail-credit {
    flex-shrink: 0;
    margin: 0;
    text-align: right;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    white-space: nowrap;
  }
  .detail-credit .credit-handle {
    color: var(--color-text);
  }
  .detail-cat {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.8rem;
  }
  .detail-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
    text-transform: uppercase;
  }
  .detail-year {
    font-weight: 300;
    text-transform: none;
    color: var(--color-text-faint);
  }
  .detail-comment {
    margin: 1.2rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
  }

  /* Galerie en colonnes explicites (flex) : ordre statique, pas de
     rééquilibrage au « Voir plus ». Le nombre de colonnes est géré en JS. */
  .detail-gallery {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }
  /* :global car les colonnes sont (re)générées en JS et n'ont pas l'attribut de scope Astro */
  .detail-gallery :global(.gallery-col) {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .detail-gallery img {
    width: 100%;
    display: block;
    border-radius: 2px;
    background: var(--color-bg-soft);
    cursor: pointer;
    transition: opacity 0.3s ease;
  }
  .detail-gallery img:hover {
    opacity: 0.7;
  }
  .detail-gallery img.is-extra {
    display: none;
  }
  .detail-gallery img.just-shown {
    animation: gallery-fade 0.5s ease both;
  }
  @keyframes gallery-fade {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  /* Bouton « Voir plus » */
  .gallery-more-wrap {
    text-align: center;
    margin-top: 3rem;
  }
  /* Bouton « Voir plus » : style verre partagé (.btn-glass dans global.css) */

  /* ---- Lightbox ---- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4vmin;
    background: rgba(5, 5, 5, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    visibility: hidden;
    cursor: pointer;
    transition: opacity 0.32s ease, visibility 0.32s;
  }
  .lightbox.is-open {
    opacity: 1;
    visibility: visible;
  }
  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 3px;
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.6);
    transform: scale(0.94);
    transition: transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .lightbox.is-open .lightbox-img {
    transform: scale(1);
  }
  .lightbox-close {
    position: absolute;
    top: 1.4rem;
    right: 1.4rem;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.7);
    cursor: pointer;
    transition: color 0.25s ease;
  }
  .lightbox-close:hover {
    color: #ffffff;
  }

  @media (max-width: 720px) {
    .projet-detail {
      padding-top: 6.5rem;
    }
    .detail-head {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.8rem;
    }
    .detail-credit {
      text-align: left;
      margin-top: 0;
    }
  }
</style>

<script>
  const gallery = document.querySelector<HTMLElement>('.detail-gallery');

  // Colonnes responsives à ordre STATIQUE : chaque photo (triée par data-i) est
  // redistribuée en round-robin dans 3 colonnes (desktop) ou 2 (mobile).
  // « Voir plus » révèle les photos déjà placées dans leur colonne → rien ne bouge.
  if (gallery) {
    const targetCols = () =>
      window.matchMedia('(max-width: 720px)').matches ? 2 : 3;

    const relayout = () => {
      const cols = targetCols();
      if (gallery.dataset.cols === String(cols)) return;
      const imgs = Array.from(gallery.querySelectorAll<HTMLImageElement>('img')).sort(
        (a, b) => Number(a.dataset.i) - Number(b.dataset.i),
      );
      const colEls = Array.from({ length: cols }, () => {
        const d = document.createElement('div');
        d.className = 'gallery-col';
        return d;
      });
      imgs.forEach((img, idx) => colEls[idx % cols].appendChild(img));
      gallery.replaceChildren(...colEls);
      gallery.dataset.cols = String(cols);
    };

    relayout();
    let resizeTimer: number;
    window.addEventListener('resize', () => {
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(relayout, 150);
    });
  }

  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;

  if (gallery && lightbox && lightboxImg) {
    // Sort la lightbox de <main> pour qu'elle passe au-dessus du header (z-index)
    document.body.appendChild(lightbox);

    const open = (src: string, alt: string) => {
      lightboxImg.src = src;
      lightboxImg.alt = alt;
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const close = () => {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };

    gallery.addEventListener('click', (e) => {
      const img = (e.target as HTMLElement).closest('img');
      if (img instanceof HTMLImageElement) open(img.src, img.alt);
    });

    // Clic n'importe où sur la lightbox (fond, image ou croix) = fermeture
    lightbox.addEventListener('click', close);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && lightbox.classList.contains('is-open')) close();
    });
  }

  // « Voir plus » — révèle les photos cachées par lots
  const moreBtn = document.getElementById('gallery-more');
  const galleryEl = document.querySelector('.detail-gallery');
  if (moreBtn && galleryEl) {
    const BATCH = 9;
    moreBtn.addEventListener('click', () => {
      const hidden = Array.from(
        galleryEl.querySelectorAll<HTMLElement>('img.is-extra'),
      )
        .sort((a, b) => Number(a.dataset.i) - Number(b.dataset.i))
        .slice(0, BATCH);
      hidden.forEach((img) => {
        img.classList.remove('is-extra');
        img.classList.add('just-shown');
      });
      if (galleryEl.querySelectorAll('img.is-extra').length === 0) {
        moreBtn.style.display = 'none';
      }
    });
  }
</script>
