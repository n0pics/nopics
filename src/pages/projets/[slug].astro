---
import fs from 'node:fs';
import path from 'node:path';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { projets, type Projet } from '@/data/projets';

export function getStaticPaths() {
  return projets
    .filter((p) => !p.comingSoon)
    .map((p) => ({ params: { slug: p.slug }, props: { projet: p } }));
}

const { projet } = Astro.props as { projet: Projet };

// Build-time : charge toutes les photos du dossier du projet.
let images: string[] = [];
if (projet.galleryDir) {
  const dir = path.join(process.cwd(), 'public', projet.galleryDir);
  try {
    images = fs
      .readdirSync(dir)
      .filter((f) => /\.(jpe?g|png|webp)$/i.test(f))
      .sort()
      .map((f) => `/${projet.galleryDir}/${f}`);
  } catch {
    images = [];
  }
}
---

<BaseLayout title={`${projet.title} — n0pics`} description={projet.comment} noFooter>
  <article class="projet-detail">
    <a href="/projets" class="detail-back">← Projets</a>

    <header class="detail-head">
      {projet.category && <p class="detail-cat">{projet.category}</p>}
      <h1 class="detail-title">
        {projet.title}<span class="detail-year"> — {projet.date}</span>
      </h1>
      {projet.comment && <p class="detail-comment">{projet.comment}</p>}
    </header>

    <div class="detail-gallery">
      {images.map((src) => (
        <img src={src} alt={projet.title} loading="lazy" decoding="async" />
      ))}
    </div>
  </article>
</BaseLayout>

<style>
  .projet-detail {
    max-width: 1100px;
    margin: 0 auto;
    padding: 8rem 1.5rem 6rem;
    color: var(--color-text);
  }

  .detail-back {
    display: inline-block;
    font-size: 0.72rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.3s ease;
  }
  .detail-back:hover {
    color: var(--color-text);
  }

  .detail-head {
    max-width: 680px;
    margin-bottom: 3rem;
  }
  .detail-cat {
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin: 0 0 0.8rem;
  }
  .detail-title {
    font-size: clamp(2.2rem, 6vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.05;
    margin: 0;
    text-transform: uppercase;
  }
  .detail-year {
    font-weight: 300;
    text-transform: none;
    color: var(--color-text-faint);
  }
  .detail-comment {
    margin: 1.2rem 0 0;
    color: var(--color-text-muted);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
  }

  /* Galerie en colonnes (masonry) — on descend pour tout voir */
  .detail-gallery {
    columns: 2;
    column-gap: 1rem;
  }
  .detail-gallery img {
    width: 100%;
    display: block;
    margin-bottom: 1rem;
    break-inside: avoid;
    border-radius: 2px;
    background: var(--color-bg-soft);
  }

  @media (max-width: 760px) {
    .projet-detail {
      padding-top: 6.5rem;
    }
    .detail-gallery {
      columns: 1;
    }
  }
</style>
